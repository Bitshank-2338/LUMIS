# Copy this to .env.local and fill in your values

# Backend API (Flask) — change this for production
NEXT_PUBLIC_API_BASE=http://localhost:5002
NEXT_PUBLIC_CRISIS_API_BASE=http://localhost:5003

# Google Maps JavaScript API key
# Get one at: https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here
